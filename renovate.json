{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 20,
  "packageRules": [
    {
      "description": "Netcracker GitHub Actions and reusable workflows",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["Netcracker/**", "netcracker/**"],
      "groupName": "netcracker-actions",
      "separateMajorMinor": false
    },
    {
      "description": "All other GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["!Netcracker/**", "!netcracker/**"],
      "groupName": "github-actions"
    },
    {
      "description": "Netcracker Docker images",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/netcracker/**"],
      "groupName": "netcracker-docker",
      "separateMajorMinor": false
    },
    {
      "description": "All other third-party Docker base images",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["!ghcr.io/netcracker/**"],
      "groupName": "docker-deps"
    },
    {
      "description": "Kubernetes-related Go modules (k8s.io and sigs.k8s.io)",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["k8s.io/**", "sigs.k8s.io/**"],
      "groupName": "k8s-go"
    },
    {
      "description": "Netcracker Go modules",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["github.com/Netcracker/**", "github.com/netcracker/**"],
      "groupName": "netcracker-go",
      "separateMajorMinor": false
    },
    {
      "description": "All other Go dependencies",
      "matchManagers": ["gomod"],
      "matchPackageNames": [
        "!k8s.io/**",
        "!sigs.k8s.io/**",
        "!github.com/Netcracker/**",
        "!github.com/netcracker/**"
      ],
      "groupName": "go-deps"
    }
  ]
}
